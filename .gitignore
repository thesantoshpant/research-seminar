# ---------------------------------------------------------------
# Sea-ice deep fusion project — what NOT to commit.
#
# Keep in git: notebooks (.ipynb), generator scripts (make_*.py,
# crop_*.py, segment_*.py), PDFs, and notebook_output/ (the small
# comparison figures used in the writeup).
#
# Everything below this line stays out of the repo because it is
# either huge raw/processed data, intermediate caches, or local
# editor/IDE/OS junk.
# ---------------------------------------------------------------

# --- Raw + processed datasets (gigabytes — never push) ---
S2_tiff/
IS2_Corrected_data/
outputs/
outputs_segmented/

# --- Bundled archives of the dataset ---
*.tar
*.tar.gz
*.tgz
*.zip
*.7z
*.rar

# --- Trained model checkpoints / training run artifacts ---
runs/
checkpoints/
*.pth
*.pt
*.ckpt
*.onnx
*.safetensors

# --- Random screenshots / scratch images at the repo root ---
Screenshot_*.jpeg
Screenshot_*.jpg
Screenshot_*.png

# --- Python bytecode + caches ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Virtualenvs ---
.venv/
venv/
env/
.env

# --- Jupyter ---
.ipynb_checkpoints/

# --- Editor / OS junk ---
.vscode/
.idea/
*.swp
*.swo
*~
*.un~
.DS_Store
Thumbs.db

# --- Tool / agent local state ---
.claude/
